# ============================================================
# LiveVoice Environment Variables
# For local dev: copy this file to .env and fill in values
# For Railway: set these in Railway dashboard > Variables tab
# ============================================================

# REQUIRED: Your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# OPTIONAL: The public URL of your deployed app
# Railway auto-provides this via $RAILWAY_PUBLIC_DOMAIN
APP_URL=""

# Set automatically by Railway in production
NODE_ENV="production"
